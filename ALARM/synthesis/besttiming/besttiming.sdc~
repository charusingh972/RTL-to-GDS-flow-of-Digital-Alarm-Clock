###############################################################
# besttiming.sdc — alarm_mt251 (timing-first but lenient)
###############################################################

# 100 MHz = 10 ns
create_clock -name clk_pb34 -period 10.000 [get_ports clk_pb34]

# Small uncertainty
set_clock_uncertainty 0.10 [get_clocks clk_pb34]

# Ports
set in_rst    [get_ports rst_rp38]
set in_async  [get_ports {btn_s_cs11 btn_c_nm30}]
set in_sync   [get_ports {set_h_cs11* set_m_nm30* en_a0_pb34 en_a1_rp38 set_a0_cs11 set_a1_nm30}]
set outs_all  [all_outputs]

# Tight-ish I/O (still lenient)
set_input_delay  0.5 -clock clk_pb34 $in_sync
set_output_delay 0.5 -clock clk_pb34 $outs_all

# Generic strong-ish drive, light load
set_drive 1.0 $in_sync
set_load  0.08 $outs_all

# Async cuts (reset + buttons)
set_false_path -from $in_rst   -to [all_registers]
set_false_path -from $in_async

# 6) power planning 
addRing \
  -skip_via_on_wire_shape Noshape \
  -skip_via_on_pin Standardcell \
  -center 1 \
  -stacked_via_top_layer Metal9 \
  -type core_rings \
  -jog_distance 0.435 \
  -threshold 0.435 \
  -nets {GND VDD} \
  -follow core \
  -stacked_via_bottom_layer Metal1 \
  -layer {bottom Metal8 top Metal8 right Metal9 left Metal9} \
  -width 1.25 \
  -spacing 0.4 \
  -offset 0.435

addStripe \
  -skip_via_on_wire_shape Noshape \
  -block_ring_top_layer_limit Metal9 \
  -max_same_layer_jog_length 0.88 \
  -padcore_ring_bottom_layer_limit Metal7 \
  -number_of_sets 10 \
  -skip_via_on_pin Standardcell \
  -stacked_via_top_layer Metal9 \
  -padcore_ring_top_layer_limit Metal9 \
  -spacing 0.4 \
  -merge_stripes_value 0.435 \
  -layer Metal8 \
  -block_ring_bottom_layer_limit Metal7 \
  -width 0.44 \
  -nets {VDD GND} \
  -stacked_via_bottom_layer Metal1

